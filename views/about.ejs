<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>ABOUT</title>

    <style>
        body { background-color: white; }

        .title, .contact, .footer {
            background-image: linear-gradient(to right,#EE6D98,#8A5EBF);
        }

        h1 {
            font-family: 'Poppins', sans-serif;
            font-size: 2.5rem;
        }

        .heading { text-align: center; padding: 20px; }

        .para { padding: 30px; }

        .features { color: purple; padding-top: 5%; }

        .contact { border-radius: 10px; padding: 20px; }

        input, textarea {
            padding: 10px;
            border: none;
            border-radius: 10px;
            margin: 10px;
            width: 70%;
        }

        .form { padding-top: 5%; }

        @media (max-width: 991px) {
            img { width: 90%; }
        }
    </style>
</head>

<body>

<div class="title">

    <%- include('partials/aboutNavBar.ejs') -%>

    <div class="container">
        <div class="heading">
            <h1 style="color:white;">About Us</h1>
        </div>

        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="para text-center">
                    <p style="color:white;">
                        A web-based platform designed to handle court cases and provide easy access
                        to past cases for lawyers and judges. Registrars can add profiles and cases.
                        Lawyers can search old cases and are charged accordingly.
                    </p>
                </div>
            </div>
            <div class="col-lg-6 text-center my-4">
                <img src="/law1.jpg" class="img-fluid">
            </div>
        </div>
    </div>
</div>

<!-- FEATURES -->
<div class="container">
    <div class="heading">
        <h1 style="color:purple;">Features</h1>
        <p style="color:purple;">The cool features we have got in the website!!</p>
    </div>

    <div class="row align-items-center">
        <div class="col-lg-6 text-center">
            <img src="/law.jpg" class="img-fluid" style="max-width:70%;">
        </div>
        <div class="col-lg-6 features">
            <p>• Registrars can add profiles and cases.</p>
            <p>• Judges can browse and view past cases.</p>
            <p>• Lawyers can search past cases and view them.</p>
            <p>• Dedicated page for complete case details.</p>
            <p>• User-friendly Home & About pages.</p>
        </div>
    </div>
</div>

<!-- CONTACT -->
<div class="container mt-5">
    <div class="heading">
        <h1 style="color:purple;">Contact Us</h1>
        <p style="color:purple;">Have any queries? Please reach out to us.</p>
    </div>

    <div class="row align-items-center">
        <div class="col-lg-6">
            <div class="contact text-center">
                <form action="/contact" method="POST">
                    <div class="form">
                        <input type="text" name="name" placeholder="Name" required>
                        <br>
                        <input type="email" name="email" placeholder="Email" required>
                        <br>
                        <input type="tel" name="mobile" placeholder="Mobile number" required>
                        <br>
                        <textarea name="message" rows="3" placeholder="Write to Us" required></textarea>
                        <br>
                        <button type="submit" class="btn"
                            style="background-color:rgb(107,14,194);color:white;">
                            Send Message
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-6 text-center my-4">
            <img src="/contact-removebg-preview.png" class="img-fluid">
        </div>
    </div>
</div>

<%- include('partials/footer.ejs') -%>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
